{
  "expo": {
    "name": "A-Darts",
    "slug": "a-darts",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./frontend/assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./frontend/assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.arianaporroche.a-darts",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./frontend/assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.adartsdevsorganization.adarts"
    },
    "web": {
      "favicon": "./frontend/assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-video",
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "a074d283-d844-43da-8414-9e215f12fbd1"
      }
    },
    "owner": "adartsdevs-organization"
  }
}